{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode-go": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Go",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "{env:OPENCODE_GO_API_KEY}"
      },
      "models": {
        "kimi-k2.7-code": {
          "name": "Kimi K2.7 Code",
          "limit": {
            "context": 262144,
            "output": 262144
          }
        }
      }
    }
  },
  "model": "opencode-go/kimi-k2.7-code",
  "permission": {
    "*": "allow",
    "external_directory": "deny",
    "webfetch": "deny",
    "websearch": "deny"
  }
}
